      "exf_calendar_update",
      "exf_notes_search",
      "exf_notes_create",
      "exf_notes_get",
      "exf_projects_list",
      "exf_projects_context",
      "exf_people_search",
      "exf_person_create",
      "exf_org_search",
      "exf_codebase_search",
      "exf_code_who_knows"
