# Copy this file to .env and fill in your keys
# Get free keys at the URLs below — you only need ONE to get started

# Google AI Studio (free) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# xAI Grok — https://console.x.ai
XAI_API_KEY=

# OpenRouter (any model) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Postgres (optional — only if using createPgStore)
# DATABASE_URL=postgres://user:pass@localhost:5432/mydb
